<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E_Invoice_Parameter</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/E_Invoice_Parameter.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    
    <style>

    </style>
</head>
<body>
    <header>
        <nav class="navbar-custom">
            <div class="navbar-container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-cloud"></i>
                    <span>Red Cloud ICT Solutions</span>
                    @{
                        var companyName = Context.Session.GetString("CompanyName");
                        if (!string.IsNullOrEmpty(companyName))
                        {
                            <span> - @companyName</span>
                        }
                    }
                </a>
                
                <div class="user-info">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <span class="user-name">
                            <i class="fas fa-user-circle"></i>
                            @User.Identity.Name
                        </span>
                        
                        <!-- Logout Form (hidden) -->
                        <form id="logoutForm" asp-controller="System" asp-action="Logout" method="post" style="display:none;">
                            @Html.AntiForgeryToken()
                        </form>

                        <!-- Logout Button -->
                        <a href="javascript:void(0);" onclick="document.getElementById('logoutForm').submit();" class="logout-btn">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </a>
                    }
                    else
                    {
                        <a asp-controller="System" asp-action="Login" class="logout-btn">
                            <i class="fas fa-sign-in-alt"></i> Login
                        </a>
                    }
                </div>
            </div>
        </nav>
    </header>
    
    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Red Cloud ICT Solutions - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>