<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E_Invoice_Parameter</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    
    <style>

    </style>
</head>
<body>
    <header>
        <nav class="navbar-custom">
            <div class="d-flex justify-content-between">
                <a class="navbar-brand" asp-area="" asp-controller="System" asp-action="Parameters">
                    <i class="fas fa-cloud"></i>
                    <span>Red Cloud ICT Solutions</span>
                    @{
                        var companyName = Context.Session.GetString("CompanyName");
                        if (!string.IsNullOrEmpty(companyName))
                        {
                            <span> - @companyName</span>
                        }
                    }
                </a>
                <div class="user-info">
                        <span class="user-name">
                            <i class="fas fa-user-circle"></i>
                            @User.Identity.Name
                        </span>
                        
                        <form id="logoutForm" asp-controller="System" asp-action="Logout" method="post" style="display:none;">
                            @Html.AntiForgeryToken()
                        </form>

                        <!-- Logout Button -->
                        <a href="javascript:void(0);" onclick="document.getElementById('logoutForm').submit();" class="logout-btn">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </a>
                </div>
            </div>
        </nav>
    </header>
    
    <main role="main">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Red Cloud ICT Solutions PLC. All rights reserved.
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
            document.addEventListener('contextmenu', function (e) {
                e.preventDefault();
                return false;
            });

            document.addEventListener('keydown', function (e) {
                if (e.key === 'F12') {
                    e.preventDefault();
                    return false;
                }
                if (e.ctrlKey && e.shiftKey && e.key === 'I') {
                    e.preventDefault();
                    return false;
                }
                if (e.ctrlKey && e.shiftKey && e.key === 'J') {
                    e.preventDefault();
                    return false;
                }
                if (e.ctrlKey && e.shiftKey && e.key === 'C') {
                    e.preventDefault();
                    return false;
                }
                if (e.ctrlKey && e.key === 'u') {
                    e.preventDefault();
                    return false;
                }
                if (e.metaKey && e.altKey && e.key === 'I') {
                    e.preventDefault();
                    return false;
                }
            });
    </script>
</body>
</html>