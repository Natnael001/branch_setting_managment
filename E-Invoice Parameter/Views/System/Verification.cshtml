@{
    ViewData["Title"] = "Identification Verification";
    Layout = null;
}


<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<link rel="stylesheet" href="~/css/verification.css" asp-append-version="true">

<div class="verification-wrapper">
    <div class="company-header">
        <div class="company-name">
            <i class="fas fa-cloud"></i>
            RED CLOUD
        </div>
    </div>

    <div class="content-box">

        <div class="error-message" id="errorMessage">
            <i class="fas fa-exclamation-circle"></i>
            <span id="errorText">Invalid identification number. Please try again.</span>
        </div>

        <div class="verify-title">
            <i class="fas fa-shield-alt"></i>
            Please verify your identification no. to continue
        </div>

        <div class="form-group">
            <label><i class="fas fa-id-card"></i> Identification No.</label>
            <input type="text" class="form-control" id="identificationNo" placeholder="Enter identification number" autofocus>
        </div>

        <div class="checkbox-group">
            <label class="checkbox-container">
                <input type="checkbox" id="rememberMe">
                <span class="checkmark">
                    <i class="fas fa-check"></i>
                </span>
                <span class="remember-text">Remember</span>
            </label>
        </div>

        <button class="btn-verify" onclick="verifyIdentification()" id="verifyBtn">
            <i class="fas fa-check-circle"></i> Verify
        </button>
    </div>
</div>

<script src="~/js/verification.js" asp-append-version="true"></script>