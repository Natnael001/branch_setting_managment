@* UserManagement.cshtml *@
@{
    ViewData["Title"] = "User Management";
    // Cast ViewBag items to a list to avoid runtime binding issues with anonymous types
    var users = ViewBag.Users as IEnumerable<dynamic>;
    var employees = ViewBag.Employees as IEnumerable<dynamic>;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<link rel="stylesheet" href="~/css/shared.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/user-management.css" asp-append-version="true">

        <div class="container">

            <div class="system-header">
                <div class="system-title">
                    <i class="fas fa-users-cog"></i>
                    User Management
                </div>
                <div class="header-actions">
                    <a href="@Url.Action("CreateUser")" class="btn btn-create">
                        <i class="fas fa-user-plus"></i> Create New User
                    </a>
                    <a href="@Url.Action("Parameters")" class="btn btn-parameters">
                        <i class="fas fa-cog"></i> Parameters
                    </a>
                </div>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">
                    <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                    <button type="button" class="alert-close" onclick="this.parentElement.style.display='none'">&times;</button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-error">
                    <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
                    <button type="button" class="alert-close" onclick="this.parentElement.style.display='none'">&times;</button>
                </div>
            }

            <div class="user-management-content">
                <div class="users-list-section">
                    <div class="section-header">
                        <i class="fas fa-users"></i> System Users
                    </div>

                    @if (users != null && users.Any())
                    {
                        <div class="table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>Username</th>
                                        <th>Employee</th>
                                        <th>Roles</th>
                                        <th>Status</th>
                                        <th>Created</th>
                                        <th>Last Login</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in users)
                                    {
                                        <tr>
                                            <td><strong>@(user?.UserName ?? "N/A")</strong></td>
                                            <td>@(user?.EmployeeName ?? "Unknown")</td>
                                            <td>
                                                @if (user?.Roles != null && user.Roles.Count > 0)
                                                {
                                                    foreach (var role in user.Roles)
                                                    {
                                                        <span class="role-badge">@role</span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">No role</span>
                                                }
                                            </td>
                                            <td>
                                                @if (user?.IsActive == true)
                                                {
                                                    <span class="status-badge status-active">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="status-badge status-inactive">Inactive</span>
                                                }
                                            </td>
                                            <td>@(user?.CreatedAt.ToString("yyyy-MM-dd") ?? "-")</td>
                                            <td>@(user?.LastLoginAt?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</td>
                                            <td class="action-buttons">
                                                <a href="@Url.Action("EditUser", new { id = user?.Id })" class="action-icon edit-icon" title="Edit">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <button onclick="toggleUserStatus(@(user?.Id ?? 0))" class="action-icon @(user?.IsActive == true ? "deactivate-icon" : "activate-icon")" title="@(user?.IsActive == true ? "Deactivate" : "Activate")">
                                                    <i class="fas @(user?.IsActive == true ? "fa-ban" : "fa-check-circle")"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-users"></i>
                            <p>No users found.</p>
                        </div>
                    }
                </div>

                <div class="employees-section">
                    <div class="section-header">
                        <i class="fas fa-user-tie"></i> Employees Without User Accounts
                    </div>

                    @if (employees != null)
                    {
                        var employeesWithoutAccount = employees.Where(e => e.HasUser == false).ToList();

                        if (employeesWithoutAccount.Any())
                        {
                            <div class="table-responsive">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>Employee Name</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var emp in employeesWithoutAccount)
                                        {
                                            <tr>
                                                <td>@emp.FullName</td>
                                                <td>
                                                    <a href="@Url.Action("CreateUser")?firstName=@emp.FirstName&secondName=@emp.SecondName" class="create-account-link">
                                                        <i class="fas fa-user-plus"></i> Create Account
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="empty-state small">
                                <i class="fas fa-check-circle" style="color: #28a745;"></i> All employees have user accounts.
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state small">
                            No employees found.
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Anti-forgery token -->
        @inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
        @{
            var token = Antiforgery.GetAndStoreTokens(Context).RequestToken;
        }
        <input type="hidden" id="RequestVerificationToken" value="@token" />

        <script src="~/js/user-management.js" asp-append-version="true"></script>