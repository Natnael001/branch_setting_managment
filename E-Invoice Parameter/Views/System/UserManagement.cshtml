@{
    ViewData["Title"] = "User Management";
    var users = ViewBag.Users as IEnumerable<dynamic>;
    var employees = ViewBag.Employees as IEnumerable<dynamic>;
}
<!DOCTYPE html>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<link rel="stylesheet" href="~/css/shared.css" asp-append-version="true">
<link rel="stylesheet" href="~/css/user-management.css" asp-append-version="true">

 <div class="container">
     <div class="system-header">
         <div class="system-title">
             <i class="fas fa-users-cog"></i>
             User Management
         </div>
         <div class="header-actions">
             <a href="@Url.Action("CreateUser")" class="btn btn-create">
                 <i class="fas fa-user-plus"></i> Create New User
             </a>
             <a href="@Url.Action("Parameters")" class="btn btn-parameters">
                 <i class="fas fa-cog"></i> Parameters
             </a>
         </div>
     </div>

     @if (TempData["SuccessMessage"] != null)
     {
         <div class="alert alert-success">
             <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
             <button type="button" class="alert-close" onclick="this.parentElement.style.display='none'">&times;</button>
         </div>
     }

     @if (TempData["ErrorMessage"] != null)
     {
         <div class="alert alert-error">
             <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
             <button type="button" class="alert-close" onclick="this.parentElement.style.display='none'">&times;</button>
         </div>
     }

     <div class="main-content">
         <div class="forms-section" style="width: 100%;">
             <div class="section-header">
                 <i class="fas fa-users"></i>
                 System Users
                 <span class="selected-branch">
                     (@(users?.Where(u => u.IsActive == true).Count() ?? 0) Users)
                 </span>
             </div>

             <div class="forms-container">
                 <div class="user-filter">
                     <div class="filter-group">
                         <input type="text" class="filter-input" id="userFilter" placeholder="Filter users by name or username..." onkeyup="filterUsers(this)">
                         <button class="btn-clear" onclick="clearUserFilter()">
                             <i class="fas fa-times"></i>
                         </button>
                     </div>
                 </div>
                 @if (users != null && users.Any())
                 {
                     <div class="table-responsive">
                                <table class="user-table" id="usersTable">
                             <thead>
                                 <tr>
                                     <th>Username</th>
                                     <th>Employee</th>
                                     <th>Roles</th>
                                     <th>Status</th>
                                     <th>Created</th>
                                     <th>Last Login</th>
                                     <th>Actions</th>
                                 </tr>
                             </thead>
                             <tbody>
                                 @foreach (var user in users)
                                 {
                                     @if (user?.IsActive == true)
                                     {
                                         <tr>
                                             <td class="device-name">
                                                 <strong>@(user?.UserName ?? "N/A")</strong>
                                             </td>
                                             <td>@(user?.EmployeeName ?? "Unknown")</td>
                                             <td>
                                                 @if (user?.Roles != null && user.Roles.Count > 0)
                                                 {
                                                     foreach (var role in user.Roles)
                                                     {
                                                         <span class="role-badge" style="background:#e65c00; color:white; padding:4px 10px; border-radius:20px; font-size:12px; display:inline-block; margin:2px;">@role</span>
                                                     }
                                                 }
                                                 else
                                                 {
                                                     <span class="text-muted">No role</span>
                                                 }
                                             </td>
                                             <td>
                                                 @if (user?.IsActive == true)
                                                 {
                                                     <span class="status-badge status-active">
                                                         <i class="fas fa-check-circle"></i> Active
                                                     </span>
                                                 }
                                                 else
                                                 {
                                                     <span class="status-badge status-inactive">
                                                         <i class="fas fa-ban"></i> Inactive
                                                     </span>
                                                 }
                                             </td>
                                             <td>@(user?.CreatedAt.ToString("yyyy-MM-dd") ?? "-")</td>
                                             <td>@(user?.LastLoginAt?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</td>
                                             <td class="action-buttons">
                                                 <a href="@Url.Action("EditUser", new { id = user?.Id })" class="action-icon edit-icon" title="Edit User">
                                                     <i class="fas fa-edit"></i>
                                                 </a>
                                                 <button onclick="toggleUserStatus(@(user?.Id ?? 0))"
                                                         class="action-icon @(user?.IsActive == true ? "deactivate-icon" : "activate-icon")"
                                                         title="@(user?.IsActive == true ? "Deactivate User" : "Activate User")">
                                                     <i class="fas @(user?.IsActive == true ? "fa-ban" : "fa-check-circle")"></i>
                                                 </button>
                                             </td>
                                         </tr>
                                     }
                                 }
                             </tbody>
                         </table>
                     </div>
                 }
                 else
                 {
                     <div class="empty-state">
                         <i class="fas fa-users"></i>
                         <p>No users found. Click "Create New User" to add one.</p>
                     </div>
                 }
             </div>
         </div>
     </div>

     <div class="main-content" style="margin-top: 30px;">
         <div class="forms-section" style="width: 100%;">
             <div class="section-header">
                 <i class="fas fa-user-tie"></i>
                 Employees Without User Accounts
                 <span class="selected-branch">(@(employees?.Where(e => e.HasUser == false).Count() ?? 0) employees)</span>
             </div>

             <div class="forms-container">
                 @if (employees != null)
                 {
                     var employeesWithoutAccount = employees.Where(e => e.HasUser == false).ToList();

                     if (employeesWithoutAccount.Any())
                     {
                         <div class="table-responsive">
                                    <table class="user-table">
                                 <thead>
                                     <tr>
                                         <th>Employee Name</th>
                                         <th>Action</th>
                                     </tr>
                                 </thead>
                                 <tbody>
                                     @foreach (var emp in employeesWithoutAccount)
                                     {
                                         <tr>
                                             <td>@emp.FullName</td>
                                             <td>
                                                 <a href="@Url.Action("CreateUser")?firstName=@emp.FirstName&secondName=@emp.SecondName" class="create-account-link" style="color:#e65c00; text-decoration:none; display:inline-flex; align-items:center; gap:5px;">
                                                     <i class="fas fa-user-plus"></i> Create Account
                                                 </a>
                                             </td>
                                         </tr>
                                     }
                                 </tbody>
                             </table>
                         </div>
                     }
                     else
                     {
                         <div class="empty-state small">
                             <i class="fas fa-check-circle" style="color: #28a745;"></i> All employees have user accounts.
                         </div>
                     }
                 }
                 else
                 {
                     <div class="empty-state small">
                         No employees found.
                     </div>
                 }
             </div>
         </div>
     </div>
 </div>

 <!-- Anti-forgery token -->
 @inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
 @{
     var token = Antiforgery.GetAndStoreTokens(Context).RequestToken;
 }
 <input type="hidden" id="RequestVerificationToken" value="@token" />

<script src="~/js/user-management.js" asp-append-version="true"></script>