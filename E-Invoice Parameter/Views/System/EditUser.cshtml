@* EditUser.cshtml *@
@model UserCreationViewModel
@{
    ViewData["Title"] = "Edit User";
    var userId = ViewBag.UserId;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<link rel="stylesheet" href="~/css/shared.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/edit-user.css" asp-append-version="true">

        <div class="container">
            <div class="welcome-title">
                <i class="fas fa-cloud"></i>
                Welcome to <b>Red Cloud ICT Solutions PLC</b>
            </div>

            <div class="system-header">
                <div class="system-title">
                    <i class="fas fa-user-edit"></i>
                    Edit User
                </div>
                <div class="header-actions">
                    <a href="@Url.Action("UserManagement")" class="btn btn-back">
                        <i class="fas fa-arrow-left"></i> Back to Users
                    </a>
                </div>
            </div>

            <div class="content-box">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="error-message">
                        <i class="fas fa-exclamation-circle"></i>
                        <div>@Html.ValidationSummary(false)</div>
                    </div>
                }

                <div class="info-box">
                    <i class="fas fa-info-circle"></i>
                    <strong>Editing User ID: @userId</strong> - Leave password fields empty to keep current password.
                </div>

                <form asp-action="EditUser" method="post" class="user-form" id="editUserForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@userId" />

                    <div class="form-section">
                        <h4 class="section-title">
                            <i class="fas fa-user"></i> Employee Information
                        </h4>

                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="FirstName">First Name <span class="required-star">*</span></label>
                                <input asp-for="FirstName" class="form-control" required />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="SecondName">Second Name</label>
                                <input asp-for="SecondName" class="form-control" />
                                <span asp-validation-for="SecondName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="RoleId">Position/Role <span class="required-star">*</span></label>
                                <select asp-for="RoleId" class="form-control" required>
                                    <option value="">-- Select Role --</option>
                                    @if (ViewBag.Roles != null)
                                    {
                                        foreach (var role in ViewBag.Roles)
                                        {
                                            if (Model.RoleId == role.id)
                                            {
                                                <option value="@role.id" selected>@role.Name</option>
                                            }
                                            else
                                            {
                                                <option value="@role.id">@role.Name</option>
                                            }
                                        }
                                    }
                                </select>
                                <span asp-validation-for="RoleId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-section">
                        <h4 class="section-title">
                            <i class="fas fa-lock"></i> User Account Information
                        </h4>

                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="Username">Username <span class="required-star">*</span></label>
                                <input asp-for="Username" class="form-control" required minlength="3" maxlength="50" />
                                <small class="text-muted">Minimum 3 characters. Letters, numbers, dots and underscores only.</small>
                                <span asp-validation-for="Username" class="text-danger"></span>
                                <div id="usernameStatus" class="username-status"></div>
                            </div>
                        </div>

                        <div class="password-hint">
                            <i class="fas fa-key"></i>
                            Only fill in the password fields if you want to change the user's password.
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="Password">New Password</label>
                                <input asp-for="Password" type="password" class="form-control" minlength="6" />
                                <small class="text-muted">Leave empty to keep current password. Minimum 6 characters if changing.</small>
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="ConfirmPassword">Confirm New Password</label>
                                <input asp-for="ConfirmPassword" type="password" class="form-control" />
                                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group checkbox-group">
                                <label class="checkbox-container">
                                    <input asp-for="IsActive" type="checkbox" />
                                    <span class="checkmark">
                                        <i class="fas fa-check"></i>
                                    </span>
                                    <span class="remember-text">Active</span>
                                </label>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label asp-for="Remark">Remark</label>
                                <textarea asp-for="Remark" class="form-control" rows="3" placeholder="Optional notes about this user"></textarea>
                                <span asp-validation-for="Remark" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn-verify" id="submitBtn">
                            <i class="fas fa-save"></i> Update User
                        </button>
                        <a href="@Url.Action("UserManagement")" class="btn-verify btn-cancel">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>

        <!-- Anti-forgery token for AJAX calls if needed -->
        @inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
        @{
            var token = Antiforgery.GetAndStoreTokens(Context).RequestToken;
        }
        <input type="hidden" id="RequestVerificationToken" value="@token" />
        <input type="hidden" id="OriginalUsername" value="@Model.Username" />
        <input type="hidden" id="UserId" value="@userId" />

        <script src="~/js/edit-user.js" asp-append-version="true"></script>