@* EditUser.cshtml *@
@model UserCreationViewModel
@{
    ViewData["Title"] = "Edit User";
    var userId = ViewBag.UserId;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<link rel="stylesheet" href="~/css/shared.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/user-form.css" asp-append-version="true">

        <div class="container">
            

            <div class="system-header">
                <div class="system-title">
                    <i class="fas fa-user-edit"></i>
                    Edit User
                </div>
                <div class="header-actions">
                    <a href="@Url.Action("UserManagement")" class="btn btn-back">
                        <i class="fas fa-arrow-left"></i> Back to Users
                    </a>
                </div>
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-error">
                    <i class="fas fa-exclamation-circle"></i>
                    @Html.ValidationSummary(false)
                </div>
            }

            <div class="info-box" style="background: #fff2eb; border-left: 4px solid #e65c00; padding: 12px 16px; border-radius: 6px; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
                <i class="fas fa-info-circle" style="color: #e65c00;"></i>
                <strong>Editing User ID: @userId</strong> - Leave password fields empty to keep current password.
            </div>

            <div class="main-content">
                <div class="forms-section" style="width: 100%;">
                    <div class="section-header">
                        <i class="fas fa-info-circle"></i>
                        User Information
                    </div>

                    <div class="forms-container">
                        <form id="editUserForm" method="post" asp-action="EditUser">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@userId" />

                            <div class="form-grid">
                                <!-- Left column -->
                                <div class="form-column">
                                    <div class="form-group">
                                        <label>
                                            <i class="fas fa-user"></i> First Name <span class="required">*</span>
                                        </label>
                                        <input asp-for="FirstName" class="form-control" required />
                                        <span asp-validation-for="FirstName" class="text-danger"></span>
                                    </div>

                                    <div class="form-group">
                                        <label>
                                            <i class="fas fa-user"></i> Second Name
                                        </label>
                                        <input asp-for="SecondName" class="form-control" />
                                        <span asp-validation-for="SecondName" class="text-danger"></span>
                                    </div>

                                    <div class="form-group">
                                        <label>
                                            <i class="fas fa-briefcase"></i> Position/Role <span class="required">*</span>
                                        </label>
                                        <select asp-for="RoleId" class="form-control" required>
                                            <option value="">-- Select Role --</option>
                                            @if (ViewBag.Roles != null)
                                            {
                                                foreach (var role in ViewBag.Roles)
                                                {
                                                    if (Model.RoleId == role.id)
                                                    {
                                                        <option value="@role.id" selected>@role.Name</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@role.id">@role.Name</option>
                                                    }
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="RoleId" class="text-danger"></span>
                                    </div>
                                </div>

                                <!-- Right column -->
                                <div class="form-column">
                                    <div class="form-group">
                                        <label>
                                            <i class="fas fa-user-circle"></i> Username <span class="required">*</span>
                                        </label>
                                        <input asp-for="Username" class="form-control" required minlength="3" maxlength="50" />
                                        <small class="text-muted">Minimum 3 characters. Letters, numbers, dots and underscores only.</small>
                                        <span asp-validation-for="Username" class="text-danger"></span>
                                        <div id="usernameStatus" class="username-status"></div>
                                    </div>

                                    <div class="password-hint" style="background: #fff2eb; border: 1px solid #ffb399; color: #cc5200; padding: 12px; border-radius: 6px; margin-bottom: 20px; font-size: 13px; display: flex; align-items: center; gap: 8px;">
                                        <i class="fas fa-key"></i>
                                        Only fill in the password fields if you want to change the user's password.
                                    </div>

                                    <div class="form-group">
                                        <label>
                                            <i class="fas fa-lock"></i> New Password
                                        </label>
                                        <input asp-for="Password" type="password" class="form-control" minlength="6" />
                                        <small class="text-muted">Leave empty to keep current password. Minimum 6 characters if changing.</small>
                                        <span asp-validation-for="Password" class="text-danger"></span>
                                    </div>

                                    <div class="form-group">
                                        <label>
                                            <i class="fas fa-lock"></i> Confirm New Password
                                        </label>
                                        <input asp-for="ConfirmPassword" type="password" class="form-control" />
                                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                    </div>

                                    <div class="checkbox-group">
                                        <label class="checkbox-container">
                                            <input asp-for="IsActive" type="checkbox" />
                                            <span class="checkmark"><i class="fas fa-check"></i></span>
                                            <span class="checkbox-text"><i class="fas fa-check-circle"></i> Active</span>
                                        </label>
                                    </div>

                                    <div class="form-group">
                                        <label>
                                            <i class="fas fa-comment"></i> Remark
                                        </label>
                                        <textarea asp-for="Remark" class="form-control" rows="2" placeholder="Optional notes about this user"></textarea>
                                        <span asp-validation-for="Remark" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="form-actions">
                                <button type="submit" class="btn btn-save">
                                    <i class="fas fa-save"></i> Update User
                                </button>
                                <a href="@Url.Action("UserManagement")" class="btn btn-cancel">
                                    Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Anti-forgery token for AJAX calls -->
        @inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
        @{
            var token = Antiforgery.GetAndStoreTokens(Context).RequestToken;
        }
        <input type="hidden" id="RequestVerificationToken" value="@token" />
        <input type="hidden" id="OriginalUsername" value="@Model.Username" />
        <input type="hidden" id="UserId" value="@userId" />

        <script src="~/js/edit-user.js" asp-append-version="true"></script>